#!/usr/bin/env bash

# Set the ansible playbook dir
ANSIBLE_DIR=$HOME/Github/Ansible-Playbooks

# Run bootstrap.yml, ignore ssh key, login as root, if no comma assume inventory is in "hosts" directory.
function bootstrap() { # short for `cdfinder`
	cd $ANSIBLE_DIR;
	ansible-playbook bootstrap.yml --ssh-extra-args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null' -u root -i "$@"
}

# Run deploy.yml with clean-install tags
function deploy() {
	
}

# Run deploy.yml with clean-install tags
function clean-install() {
	deploy("$@ + tags all,clean-install")
}

# Run migrate.yml, use hosts/migrate for inventory, rewrite inventory afterwards
function migrate() {

}

# Execute a script if given a file, otherwise treat the cd as a project root
# and try to identify and build it.
function build() {

	if [[ $# -gt 0 ]]; then
		build "$@";
	elif [[ -e Cargo.toml ]]; then
		echo "Cargo (Rust) project detected."
		cargo build;
	elif [[ -e build.sbt ]]; then
		echo "SBT (Scala) project detected."
		sbt build;
	elif [[ -e project.clj ]]; then
		echo "Leiningen (Clojure) project detected."
		lein uberjar;
	else
		echo "Could not identify the project to be run.";
	fi;
}

# Execute a script if given a file, otherwise treat the cd as a project root
# and try to identify and build it.
function run() {

	if [[ $# -gt 0 ]]; then
		source "$@"; # if given arguments, try to execute as a script
	elif [[ -e Cargo.toml ]]; then
		echo "Cargo (Rust) project detected."
		cargo run "$@";
	elif [[ -e build.sbt ]]; then
		echo "SBT (Scala) project detected."
		sbt run "$@";
	elif [[ -e project.clj ]]; then
		echo "Leiningen (Clojure) project detected."
		lein run "$@";
	else
		echo "Could not identify the project to be run.";
	fi;
}

# Determine size of a file or total size of a directory
function sizeof() {
	if du -b /dev/null > /dev/null 2>&1; then
		local arg=-sbh;
	else
		local arg=-sh;
	fi
	if [[ -n "$@" ]]; then
		du $arg -- "$@";
	else
		du $arg .[^.]* ./*;
	fi;
}
